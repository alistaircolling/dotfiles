  //   ],
  //   "validateSyntaxBeforeApplying": true,
  //   "createUndoPointBeforeChanges": true,
  //   "preventFileDeletion": true,
  //   "maxChangeSize": 500
  // },
  "editor.autoIndent": "full",
  "editor.minimap.enabled": false,
  "editor.renderWhitespace": "none",
  "zenMode.centerLayout": false,
  "zenMode.hideLineNumbers": true,
  "zenMode.hideStatusBar": false,
  "search.collapseResults": "alwaysCollapse",
  "typescript.preferences.importModuleSpecifier": "relative",
  "workbench.editor.showTabs": "none",
  "zenMode.showTabs": "none",
  "workbench.sideBar.location": "left",
  "scm.diffDecorations": "none",
  "scm.diffDecorationsGutterVisibility": "hover",
  "scm.diffDecorationsGutterWidth": 1,
  "debug.allowBreakpointsEverywhere": true,
  "editor.scrollbar.vertical": "hidden",
  "workbench.colorCustomizations": {
    "editor.commentGlyphForeground":"#ffffff"
  },
  "editor.tokenColorCustomizations": {
    "comments": "#ff97fc"
  },
  // "workbench.colorCustomizations": {
  //   "terminalCursor.foreground": "#ff00e1",
  //   "[Community Material Theme High Contrast]": {
  //     "editorCursor.foreground": "#ff00e1"
  //   },
  //   "editor.selectionBackground": "#ff00e1",
  //   "editor.selectionHighlightBorder": "#ff00e1",
  //   "editor.selectionHighlightBackground": "#ff000000",
  //   "editor.selectionForeground": "#000000",
  //   "editor.lineHighlightBackground": "#0818449e",
  //   "editor.background": "#2a2a2a",
  //   "statusBar.background": "#000000",
  //   "statusBar.foreground": "#ffffff",
  //   "statusBar.noFolderBackground": "#000000",
  //   "editor.findMatchBackground": "#ff00e1"
  // },
  // "apc.electron": {
  //   "opacity": 0.55,
  //   "transparent": true,
  //   "backgroundColor": "#00000000",
  //   "vibrancy": "ultra-dark"
  // },
  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "vim.easymotion": true,
  "vim.autoindent": true,
  "vim.easymotionMarkerBackgroundColor": "#2b17ffa0",
  "vim.easymotionMarkerForegroundColorOneChar": "#ffffff",
  "vim.easymotionMarkerForegroundColorTwoCharFirst": "#ffffff",
  "vim.easymotionMarkerForegroundColorTwoCharSecond": "#ffffff",
  "vim.statusBarColors.normal": "#000000",
  "prettier.endOfLine": "auto",
  "git.autofetch": true,
  "typescript.updateImportsOnFileMove.enabled": "always",
  "editor.matchBrackets": "never",
  "javascript.updateImportsOnFileMove.enabled": "never",
  "githubPullRequests.fileListLayout": "flat",
  "workbench.editor.labelFormat": "short",
  "debug.javascript.autoAttachFilter": "disabled",
  "editor.cursorStyle": "line",
  "editor.wordSeparators": "/\\()\"':,.;<>~!@#$%^&*|+=[]{}`?-",
  "files.insertFinalNewline": true,
  "diffEditor.renderSideBySide": false,
  "githubPullRequests.createOnPublishBranch": "never",
  "editor.guides.indentation": false,
  "[sql]": {
    "editor.defaultFormatter": "adpyke.vscode-sql-formatter"
  },
  "githubPullRequests.pullBranch": "never",
  "[html]": {
    "editor.defaultFormatter": "vscode.html-language-features"
  },
  //"eslint.format.enable": true,
  //"eslint.enable": true,
 // "eslint.options": {
  //  "overrideConfigFile": ".eslintrc.js"
  //},
 // "[vue]": {
  //  "editor.defaultFormatter": "dbaeumer.vscode-eslint"
  //},
  "editor.unicodeHighlight.allowedCharacters": {
    "’": true,
    "‘": true
  },
  "workbench.startupEditor": "none",
  // "[python]": {
  //   "editor.defaultFormatter": "ms-python.python"
  // },
  "editor.inlineSuggest.enabled": false,
  "github.copilot.enable": {
    "*": false,
    "plaintext": false,
    "markdown": false,
    "scminput": false,
    "typescriptreact": false,
    "typescript": true,
    "json": true,
    "javascript": true
  },
  "terminal.external.osxExec": "Warp.app",
  "editor.formatOnType": false,
  "editor.formatOnSaveMode": "file",
  "files.autoSave": "onFocusChange",
  "[jsonc]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "notebook.lineNumbers": "on",
  "typescript.validate.enable": true,
  "window.commandCenter": true,
  "workbench.editor.enablePreview": false,
  "editor.lineHeight": 1.5,
  "editor.letterSpacing": 0,
  "security.workspace.trust.untrustedFiles": "open",
  "vim.useSystemClipboard": true,
  "vim.leader": "<space>",
