#!/bin/sh
# Fires after history rewrites (e.g. rebase, commit --amend) update the tree.
# Detached and fully redirected: git waits for the hook AND for anything still
# holding its stdout/stderr pipe, so both are needed to guarantee git never
# blocks on the reload (see scripts/dotfiles-reload.sh for the RPC watchdog).
/Users/Shared/dotfiles/scripts/dotfiles-reload.sh >/dev/null 2>&1 &
exit 0
